# ============================================================
# HR Hiring Platform — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=true

# --- Database ---
# For local dev: SQLite (zero setup)
DATABASE_URL=sqlite+aiosqlite:///./hr_platform.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hr_platform

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- Groq LLM (FREE) ---
# Get your free API key at https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama3-8b-8192

# --- Embeddings (FREE — runs locally, no API key needed) ---
# Model downloaded automatically on first run (~90MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- ChromaDB (FREE — local persistent storage) ---
CHROMA_PERSIST_PATH=./chroma_data
# For production ChromaDB server:
# CHROMA_HOST=localhost
# CHROMA_PORT=8002

# --- Microsoft Graph (optional — for interview scheduling) ---
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
GRAPH_ORGANIZER_EMAIL=hr@yourcompany.com

# --- Redis (for Celery, production only) ---
REDIS_URL=redis://localhost:6379/0

# --- File Storage ---
UPLOAD_DIR=./uploads/resumes

# --- Scoring Thresholds ---
SCORE_HIGHLY_SUITABLE=80
SCORE_SUITABLE=60
SCORE_MANUAL_REVIEW=40
SCORE_SHORTLIST_THRESHOLD=60
